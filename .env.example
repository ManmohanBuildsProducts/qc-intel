# QC Intel — Environment Variables
# Copy this file to .env and fill in your values

# Google Gemini API key (required for normalizer + analyst)
# Get one at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Optional: override DB path (default: data/qc_intel.db)
# QC_DB_PATH=data/qc_intel.db
