# QC Intel — Environment Variables
# Copy this file to .env and fill in your values

# === Required ===

# Google Gemini API key (required for scraper, normalizer, analyst)
# Get one at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# === Optional (defaults shown) ===

# SQLite database path
# QC_DB_PATH=data/qc_intel.db

# Comma-separated CORS allowed origins for the FastAPI dashboard
# QC_ALLOWED_ORIGINS=http://localhost:3000

# Embedding model (sentence-transformers)
# QC_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Similarity threshold for cross-platform product matching
# QC_EMBEDDING_SIMILARITY_THRESHOLD=0.85

# Gemini model names per agent
# QC_SCRAPER_MODEL=gemini-2.5-flash
# QC_NORMALIZER_MODEL=gemini-2.5-flash
# QC_ANALYST_MODEL=gemini-2.5-flash

# Per-run budget caps (USD)
# QC_MAX_BUDGET_SCRAPER=0.50
# QC_MAX_BUDGET_NORMALIZER=1.00
# QC_MAX_BUDGET_ANALYST=3.00

# Scraping timing (seconds)
# QC_SCRAPE_DELAY_MIN=1.0
# QC_SCRAPE_DELAY_MAX=3.0

# Proxy for scraping (optional — not needed at low scale)
# Global proxy (used as fallback if per-platform proxy is not set):
# QC_PROXY_URL=http://user:pass@proxy-host:port
#
# Per-platform proxies (override global for specific platforms):
# Blinkit uses Cloudflare — proxy recommended if IP gets blocked
# QC_PROXY_URL_BLINKIT=http://scraperapi:YOUR_API_KEY@proxy-server.scraperapi.com:8001
#
# Zepto uses Akamai Bot Manager — heaviest protection, most likely to need proxy
# QC_PROXY_URL_ZEPTO=http://scraperapi:YOUR_API_KEY@proxy-server.scraperapi.com:8001
#
# Instamart uses AWS WAF — proper session flow matters more than proxy
# QC_PROXY_URL_INSTAMART=http://scraperapi:YOUR_API_KEY@proxy-server.scraperapi.com:8001
#
# ScraperAPI free tier (1000 req/month, no credit card): https://www.scraperapi.com/signup
# Example: QC_PROXY_URL=http://scraperapi:YOUR_API_KEY@proxy-server.scraperapi.com:8001
